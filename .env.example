# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is already in .gitignore.

# Stripe (test mode keys start with sk_test_ / pk_test_)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Site
NEXT_PUBLIC_SITE_URL=https://x-med.co

# Optional: Supabase (only needed if you migrate product data / orders to a DB later)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # server-only, NEVER expose to the client/browser
